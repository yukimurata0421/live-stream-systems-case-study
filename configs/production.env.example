APP_ENV=production
BASE_DIR=/home/yuki/projects/stream_v2
STREAM_KEY=REPLACE_ME
RTMP_URL=rtmps://a.rtmps.youtube.com:443/live2

# Keep these aligned with validated live settings.
FRAME_RATE=5
VIDEO_BITRATE=3400k
VIDEO_MAXRATE=3400k
VIDEO_BUFSIZE=6800k
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=48000
AUDIO_FILTER=aresample=async=1:min_hard_comp=0.030000:first_pts=0,volume=0.25

TAKEOVER_ENABLED=1
TAKEOVER_GRACE_SEC=5
TAKEOVER_FORCE_KILL=1

NOW_PLAYING_FILE=/home/yuki/projects/stream_v2/now_playing.txt
OVERLAY_DIR=/home/yuki/projects/stream_v2/ui/overlay
RUNTIME_STATE_FILE=/home/yuki/projects/stream_v2/state/runtime/stream_runtime_state.json
