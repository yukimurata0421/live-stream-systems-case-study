# stream_v3 shadow/test defaults for k3s and local validation.
# Do not put real stream keys or OAuth tokens in this file.

STREAM_V3_MODE=shadow
STREAM_V3_CUTOVER_ENABLE=0
STREAM_RUNTIME_SUPERVISOR=k8s
STREAM_K8S_NAMESPACE=stream-v3
STREAM_K8S_DRY_RUN=1

BASE_DIR=/app
STREAM_BASE_DIR=/app
PYTHONPATH=/app/src

STREAM_RUNTIME_STATE_DIR=/state
STREAM_RUNTIME_LOG_DIR=/state/logs
STREAM_V2_STATE_ROOT=/state
STREAM_V2_SOURCE_STATE_ROOT=/source-v2-readonly
STREAM_V2_MIRROR_SOURCE=stream-user@current-stream-host:/srv/stream_v2/.state/adsb-streamnew-v2/
STREAM_V2_MIRROR_SSH_OPTS="-o StrictHostKeyChecking=yes -o UserKnownHostsFile=/root/.ssh/known_hosts"

TEST_MODE=1
TEST_OUTPUT=file
TEST_OUTPUT_FILE=/state/capture/v3-test-output.mkv
REQUIRE_SYSTEMD_LAUNCH=0
ALLOW_DIRECT_STREAM_SH=1

RTMP_URL=rtmps://a.rtmps.youtube.com:443/live2
VIDEO_ENCODER=h264_nvenc
VIDEO_NVENC_PRESET=p4
VIDEO_NVENC_RC=cbr
VIDEO_NVENC_CQ=
VIDEO_NVENC_MULTIPASS=
VIDEO_NVENC_RC_LOOKAHEAD=0
VIDEO_NVENC_SPATIAL_AQ=0
VIDEO_NVENC_TEMPORAL_AQ=0
FRAME_RATE=30
VIDEO_BITRATE=3300k
VIDEO_MAXRATE=3300k
VIDEO_BUFSIZE=6600k
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=48000

STREAM1090_URL=http://stream1090.lan/stream1090/
BROWSER_URL=http://stream1090.lan/stream1090/
USE_OVERLAY_WRAPPER=1
OVERLAY_BIND_HOST=0.0.0.0
OVERLAY_VIEW_HOST=127.0.0.1
OVERLAY_PORT=18080

PULSE_SINK=stream_v3_sink
PULSE_SOURCE=stream_v3_sink.monitor
PULSE_SERVER=unix:/run/stream-pulse/native
PULSE_SHM=0
STREAM_V3_START_PULSE=1
STREAM_V3_PULSE_SOCKET=/run/stream-pulse/native
AUTO_DJ_KEEP_PULSE_SERVER=1
MUSIC_ROOT=/music/time_tags
STREAM_LOCK_DIR=/state/locks
TAKEOVER_ENABLED=0

V3_SHADOW_INTERVAL_SEC=60
V3_SUBSYSTEMS_STATUS_INTERVAL_SEC=60
V3_RECOVERY_ORCHESTRATOR_INTERVAL_SEC=60
V3_SHADOW_SLI_INTERVAL_SEC=300
V3_OPS_SUMMARY_INTERVAL_SEC=300
V3_CONTROL_TASK_TIMEOUT_SEC=45
V3_ENABLE_NOTIFY_DRY_RUN=0

YTW_API_COST_REPORT_TZ=America/Los_Angeles
YTW_API_COST_REPORT_OUTPUT_DIR=/state/reports/youtube_api_cost
YTW_API_COST_REPORT_LATEST_FILE=/state/reports/youtube_api_cost/latest.json
YTW_API_COST_BURN_RATE_LATEST_FILE=/state/reports/youtube_api_cost/open_day_latest.json
STREAM1090_REPORT_SAMPLE_SEC=5
STREAM1090_REPORT_TIMEOUT_SEC=5
STREAM1090_REPORT_VISUAL=0
STREAM1090_UPSTREAM_REPORT_SAMPLE_SEC=5
STREAM1090_UPSTREAM_REPORT_TIMEOUT_SEC=5
STREAM1090_UPSTREAM_REPORT_VISUAL=0
