# Discord notification bridge for stream-new incidents.
# Keep the real webhook URL out of git; put it in /etc/default/adsb-streamnew-notify.
STREAM_NOTIFY_ENABLED=1
STREAM_NOTIFY_DISCORD_WEBHOOK_URL=
STREAM_NOTIFY_REPEAT_SEC=60
STREAM_NOTIFY_REPORT_STALE_SEC=1800
STREAM_NOTIFY_STARTUP_GRACE_SEC=300
STREAM_NOTIFY_USERNAME=ADS-B Stream Watchdog
STREAM_NOTIFY_OUTBOX_TTL_SEC=86400
STREAM_NOTIFY_OUTBOX_MAX_PENDING=50
STREAM_NOTIFY_OUTBOX_FLUSH_LIMIT=10
