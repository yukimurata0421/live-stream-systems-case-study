# Copy to /etc/default/stream-v3-wan-observers on the delivery host.

STREAM_V3_REPO_DIR=/opt/stream_v3
WAO_STATE_DIR=/opt/stream_v3/.state/wan-observer
WAO_PUBLIC_IPV4_URL=https://api.ipify.org
WAO_ANCHOR_TIMEOUT_SEC=1.5
WAO_ANCHORS=cloudflare_v4=1.1.1.1:443,google_v4=8.8.8.8:443,cloudflare_v6=[2606:4700:4700::1111]:443,google_v6=[2001:4860:4860::8888]:443
WAO_PERSISTENT_INTERVAL_SEC=15
WAO_PERSISTENT_TIMEOUT_SEC=2.0
WAO_PERSISTENT_ANCHORS=cloudflare_v4|1.1.1.1|443|cloudflare-dns.com|cloudflare-dns.com|AS13335,google_v4|8.8.8.8|443|dns.google|dns.google|AS15169,cloudflare_v6|2606:4700:4700::1111|443|cloudflare-dns.com|cloudflare-dns.com|AS13335,google_v6|2001:4860:4860::8888|443|dns.google|dns.google|AS15169
WAO_PERSISTENT_TRIGGER_WAN_SNAPSHOT=1
WAO_PERSISTENT_WAN_SNAPSHOT_INTERVAL_SEC=5
WAO_PERSISTENT_WAN_SNAPSHOT_CYCLES=7
WAO_PERSISTENT_WAN_SNAPSHOT_COOLDOWN_SEC=120
WAO_PERSISTENT_TRIGGER_RTMPS_BURST=1
WAO_PERSISTENT_RTMPS_BURST_INTERVAL_SEC=5
WAO_PERSISTENT_RTMPS_BURST_DURATION_SEC=300
WAO_PERSISTENT_RTMPS_BURST_COOLDOWN_SEC=120

RTMPS_OBSERVER_STATE_DIR=/opt/stream_v3/.state/rtmps-observer
RTMPS_OBSERVER_NAMESPACE=stream-v3
RTMPS_OBSERVER_POD_PREFIX=stream-v3-runtime-
RTMPS_OBSERVER_CONTAINER=stream-engine

NETLINK_WAN_STATE_DIR=/opt/stream_v3/.state/wan-observer

CPE_OBSERVER_STATE_DIR=/opt/stream_v3/.state/cpe-observer
CPE_OBSERVER_LISTEN_HOST=127.0.0.1
CPE_OBSERVER_LISTEN_PORT=5514

TCPDUMP_RING_STATE_DIR=/opt/stream_v3/.state/packet-captures
TCPDUMP_RING_INTERFACE=any
TCPDUMP_RING_TCPDUMP_USER=root
TCPDUMP_RING_DURATION_SEC=1200
TCPDUMP_RING_SNAPLEN=128
# Keep public examples metadata-only and non-capturing by default. Set to 0
# locally only after accepting the packet-capture boundary.
TCPDUMP_RING_DRY_RUN=1
