# Copy to /etc/default/adsb-streamnew and replace STREAM_KEY.

BASE_DIR=/home/yuki/projects/stream_v2
DISPLAY=:99
DISPLAY_NAME=:99
PULSE_SINK=stream_sink
PULSE_SHM=0
PREFER_PIPEWIRE_PULSE=0
STREAM1090_URL=http://stream1090.lan/stream1090/
STREAM_KEY=REPLACE_WITH_YOUR_YOUTUBE_KEY
# Preferred YouTube ingest. The engine appends STREAM_KEY when not already present.
RTMP_URL=rtmps://a.rtmps.youtube.com:443/live2
TEST_MODE=0
USE_OVERLAY_WRAPPER=1
BROWSER_START_SETTLE_SEC=2
BROWSER_START_SETTLE_SEC_RESTART=0
BROWSER_START_SETTLE_SEC_TEST=0
PRE_FFMPEG_MIN_WAIT_SEC=0
PRE_FFMPEG_MIN_WAIT_SEC_RESTART=0
PRE_FFMPEG_MIN_WAIT_SEC_TEST=0
PRE_FFMPEG_RESTART_CONTEXT_MAX_AGE_SEC=300
PRE_FFMPEG_OVERLAY_READY_TIMEOUT_SEC=20
PRE_FFMPEG_OVERLAY_READY_POLL_SEC=1
PRE_FFMPEG_REQUIRE_OVERLAY_READY=0

MAP_LAT=36.35
MAP_LON=140.75
MAP_ZOOM=7.6
MAP_SCALE=0.82
MAP_ICON_SCALE=1.4
MAP_LABEL_SCALE=0.82
MAP_LARGE_MODE=1

FRAME_RATE=5
VIDEO_ENCODER=h264_nvenc
VIDEO_PRESET=ultrafast
# Used only when VIDEO_ENCODER=h264_nvenc on a host with NVIDIA driver/NVENC.
VIDEO_NVENC_PRESET=p4
VIDEO_NVENC_RC=cbr
VIDEO_NVENC_CQ=
VIDEO_NVENC_MULTIPASS=
VIDEO_NVENC_RC_LOOKAHEAD=0
VIDEO_NVENC_SPATIAL_AQ=0
VIDEO_NVENC_TEMPORAL_AQ=0
VIDEO_BITRATE=3400k
VIDEO_MAXRATE=3400k
VIDEO_BUFSIZE=6800k
# After a fast_recovery network_down or low_upload_pressure restart,
# temporarily trade image quality for RTMPS continuity while the WAN path settles.
EMERGENCY_LOW_UPLOAD_ENABLED=1
EMERGENCY_LOW_UPLOAD_TRIGGERS=network_down,low_upload_pressure
EMERGENCY_LOW_UPLOAD_DURATION_SEC=900
EMERGENCY_LOW_UPLOAD_VIDEO_BITRATE=2500k
EMERGENCY_LOW_UPLOAD_VIDEO_MAXRATE=2500k
EMERGENCY_LOW_UPLOAD_VIDEO_BUFSIZE=5000k
# Empty means keep AUDIO_BITRATE unchanged.
EMERGENCY_LOW_UPLOAD_AUDIO_BITRATE=
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=48000
AUDIO_FILTER=aresample=async=1:min_hard_comp=0.030000:first_pts=0,volume=0.2375
# Auto DJ pulse output buffer (ms). Lower reduces end-to-end audio latency.
PULSE_BUFFER_DURATION_MS=250
# Keep disabled by default.
# 2026-05-02 noData stabilization used FIFO disabled in production.
RTMP_FIFO_RECOVERY=0
RTMP_FIFO_QUEUE_SIZE=600
RTMP_FIFO_RECOVERY_WAIT_SEC=1
RTMP_FIFO_MAX_RECOVERY_ATTEMPTS=0
RTMP_FIFO_DROP_PKTS_ON_OVERFLOW=0
RTMP_FIFO_RESTART_WITH_KEYFRAME=1

TAKEOVER_ENABLED=1
TAKEOVER_GRACE_SEC=5
TAKEOVER_FORCE_KILL=1

# Keep runtime state/logs outside the code tree.
STREAM_RUNTIME_STATE_DIR=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2
STREAM_RUNTIME_LOG_DIR=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs
STREAM_V2_SOURCE_STATE_ROOT=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2
STREAM_V2_STATE_ROOT=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2
RUNTIME_STATE_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/stream_runtime_state.json
EVENT_LOG_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs/stream_engine_events.jsonl
RESTART_REASON_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/restart_reason.json
WATCHDOG_EVENT_LOG_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs/stream_watchdog_events.jsonl
WATCHDOG_OK_LOG_EVERY_SEC=300
WATCHDOG_STATS_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/stream_watchdog_stats.json
PLAY_HISTORY_JSONL_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs/play_history.jsonl

# Watchdog resilience / SLO
PULSE_RECOVER_ONLY_DJ_FIRST=1
PULSE_RECOVERY_WAIT_SEC=2
PULSE_WARN_RECENT_SEC=300
ENABLE_PULSE_PRECISION_PROBE=1
ENABLE_AUDIO_PROBE=1
AUDIO_FAIL_THRESHOLD=3
AUDIO_DJ_RESTART_FAILS=2
AUDIO_STREAM_RESTART_FAILS=3
AUDIO_TRACK_TRANSITION_GRACE_SEC=30
PULSE_ROUTE_FAIL_THRESHOLD=2
PULSE_DJ_BUFFER_LATENCY_WARN_USEC=350000
PULSE_DJ_BUFFER_LATENCY_CRIT_USEC=700000
PULSE_CAPTURE_BUFFER_LATENCY_WARN_USEC=120000
PULSE_CAPTURE_BUFFER_LATENCY_CRIT_USEC=300000
RESTART_WINDOW_SEC=600
RESTART_MAX_ATTEMPTS=3
RESTART_COOLDOWN_SEC=300
RECOVERY_STAGE_MAX=3
AUDIO_STARTUP_GRACE_SEC=45
PULSE_STAGE_WINDOW_SEC=600
AUDIO_STAGE_WINDOW_SEC=600
RUNTIME_HEARTBEAT_SEC=30
STOP_FFMPEG_TERM_GRACE_SEC=3
RUNTIME_SNAPSHOT_STALE_SEC=180
RUNTIME_STATE_GLOB=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/stream_runtime_state_*.json
OVERLAY_REQUIRE_MAP_PROXY=1
OVERLAY_REQUIRE_ADSB_JSON=1
ADSB_JSON_MAX_AGE_SEC=30
ADSB_MESSAGE_STALL_SEC=120
ENABLE_VIDEO_FRAME_PROBE=1
VIDEO_FRAME_MIN_LUMA=4
WATCHDOG_SNAPSHOT_TIMELINE_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs/watchdog_state_timeline.jsonl
SLO_PULSE_UNAVAILABLE_24H_MAX=1
SLO_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/slo_snapshot.json

# Report-only stream1090/upstream baseline sampling.
# Visual probes use headless Chromium and are intentionally disabled by default.
STREAM1090_REPORT_SAMPLE_SEC=5
STREAM1090_REPORT_TIMEOUT_SEC=5
STREAM1090_REPORT_VISUAL=0
STREAM1090_UPSTREAM_REPORT_SAMPLE_SEC=5
STREAM1090_UPSTREAM_REPORT_TIMEOUT_SEC=5
STREAM1090_UPSTREAM_REPORT_VISUAL=0
