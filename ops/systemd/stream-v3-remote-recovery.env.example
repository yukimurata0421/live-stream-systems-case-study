# Copy to /etc/default/stream-v3-remote-recovery on the observability host.
# Public defaults are fail-closed. Set APPLY flags to 1 only on the live host
# after kubeconfig, RBAC, action-plan ownership, and cooldown policy are verified.

STREAM_V3_REPO_DIR=/opt/stream_v3
STREAM_K8S_NAMESPACE=stream-v3
STREAM_V3_RECOVERY_PROMETHEUS_URL=http://127.0.0.1:9090
STREAM_V3_RECOVERY_JOB=stream_v3_observability_monitor
STREAM_V3_REMOTE_RECOVERY_APPLY=0
STREAM_V3_REMOTE_RECOVERY_APPLY_ACTION_PLAN=0
STREAM_V3_REMOTE_RECOVERY_STATE_FILE=/opt/stream_v3/.state/remote-recovery/state.json
STREAM_V3_REMOTE_RECOVERY_ACTION_PLAN_FILE=/opt/stream_v3/.state/observability-monitor/recovery_action_plan.json
STREAM_V3_REMOTE_RECOVERY_ACTION_PLAN_MAX_AGE_SEC=180
STREAM_V3_REMOTE_RECOVERY_COOLDOWN_SEC=600
STREAM_V3_REMOTE_RECOVERY_ACTION_TIMEOUT_SEC=45
STREAM_V3_RECOVERY_WORKLOADS=deployment/stream-v3-runtime
