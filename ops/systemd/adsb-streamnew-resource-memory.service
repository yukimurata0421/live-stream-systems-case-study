[Unit]
Description=ADS-B Stream-New resource memory diagnostic snapshot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=yuki
Group=yuki
WorkingDirectory=/home/yuki/projects/stream_v3
EnvironmentFile=-/home/yuki/projects/stream_v2/.state/env/stream-v3-observability-monitor.env
Environment=PYTHONPATH=/home/yuki/projects/stream_v3/src
ExecStart=/home/yuki/projects/stream_v3/bin/stream-prod resource-memory
