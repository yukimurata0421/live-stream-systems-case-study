# Copy to /etc/default/adsb-streamnew-fast-recovery

FR_STREAM_SERVICE=adsb-streamnew-youtube-stream.service
FR_RTMP_HOST=a.rtmps.youtube.com
FR_DNS_HOST=a.rtmps.youtube.com
FR_RTMP_PORTS=443
FR_PUBLIC_PING_TARGETS=1.1.1.1,8.8.8.8

# Runtime state is memory-backed (/dev/shm, reset on reboot).
FR_STATE_FILE=/dev/shm/adsb-streamnew/fast_recovery_state.json

# Persistent log is event-based. TCP send Mbps is sampled at a low cadence for bandwidth SLI.
FR_EVENT_LOG_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/logs/fast_recovery_events.jsonl
FR_YTW_STATS_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/youtube_watchdog_stats.json
FR_QUOTA_STATE_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/youtube_quota_state.json
FR_RESTART_REASON_FILE=/home/yuki/projects/stream_v2/.state/adsb-streamnew-v2/restart_reason.json
FR_TCP_SEND_SAMPLE_LOG_SEC=60

# URL-preservation mode: if broadcast is live and OAuth says inactive/noData, recover quickly.
FR_URL_PRESERVATION_MODE=1
FR_REMOTE_WARNING_CONFIRM=2
FR_REMOTE_WARNING_REQUIRE_LOCAL_OK=1
FR_REMOTE_WARNING_CONFIRM_DISTINCT_STATS=1
FR_YTW_STATUS_MAX_AGE_SEC=180

# Restart quickly on hard network failures.
FR_NET_FAIL_CONFIRM=1

# Ask the stream engine to start with a temporary lower video bitrate after
# hard network_down restarts or confirmed low-upload pressure while RTMPS TCP
# is still alive. Low-upload pressure requires both low send Mbps and queued
# TCP backlog, so a quiet/noisy single throughput sample is not enough.
FR_EMERGENCY_LOW_UPLOAD_ENABLED=1
FR_EMERGENCY_LOW_UPLOAD_TRIGGERS=network_down,low_upload_pressure
FR_EMERGENCY_LOW_UPLOAD_DURATION_SEC=900
FR_EMERGENCY_LOW_UPLOAD_VIDEO_BITRATE=2500k
FR_EMERGENCY_LOW_UPLOAD_VIDEO_MAXRATE=2500k
FR_EMERGENCY_LOW_UPLOAD_VIDEO_BUFSIZE=5000k
FR_EMERGENCY_LOW_UPLOAD_AUDIO_BITRATE=

FR_LOW_UPLOAD_PRESSURE_ENABLED=1
FR_LOW_UPLOAD_PRESSURE_CONFIRM=3
FR_LOW_UPLOAD_PRESSURE_MAX_MBPS=3.2
FR_LOW_UPLOAD_PRESSURE_NOTSENT_BYTES=524288
FR_LOW_UPLOAD_PRESSURE_UNACKED=256
FR_LOW_UPLOAD_PRESSURE_LASTSND_MS=1000

# Confirm TCP stall after two cycles (timer=5s -> about 10s).
FR_STALL_CONFIRM=2
FR_STALL_LASTSND_MS=4000
FR_STALL_NOTSENT_BYTES=8192
FR_STALL_UNACKED=64

# Skip checks while FFmpeg is very young.
FR_MIN_FFMPEG_UPTIME_SEC=20
# Restart stream if stream service is alive but FFmpeg is missing long enough.
FR_FFMPEG_MISSING_RESTART_SEC=20
# If restarts succeed but FFmpeg still does not return, slow the loop down.
FR_FFMPEG_MISSING_SUCCESS_BACKOFF_SEC=60

# Avoid duplicate restart calls in the same moment.
FR_RESTART_GUARD_SEC=5
# Back off when systemctl restart itself fails.
FR_RESTART_FAILURE_BACKOFF_SEC=30

# Restart-induced downtime budget.
FR_HOURLY_DOWNTIME_BUDGET_SEC=300
FR_DAILY_DOWNTIME_BUDGET_SEC=1800
FR_RESTART_DOWNTIME_COST_SEC=30
# Budgets are anti-loop guardrails, not a hard refusal to recover a public outage.
FR_BUDGET_EMERGENCY_OVERRIDE_SEC=90

# Memory sample ring size (few MB range with defaults).
FR_SAMPLES_MAX=1024
