# Copy to /etc/default/stream-v3-observability-monitor on the observability host if local paths differ.
PYTHONPATH=/home/yuki/projects/stream_v3/src
STREAM_V3_MODE=monitor
STREAM_V3_CUTOVER_ENABLE=1
STREAM_RUNTIME_SUPERVISOR=k8s
STREAM_K8S_NAMESPACE=stream-v3
STREAM_K8S_DRY_RUN=0
STREAM_RUNTIME_STATE_DIR=/home/yuki/projects/stream_v3/.state/observability-monitor
STREAM_RUNTIME_LOG_DIR=/home/yuki/projects/stream_v3/.state/observability-monitor/logs
STREAM_V2_SOURCE_STATE_ROOT=/home/yuki/projects/stream_v3/.state/observability-monitor
STREAM_V3_STREAM_CLI_BIN=/home/yuki/projects/stream_v3/bin/stream-prod
FR_STREAM_SERVICE=adsb-streamnew-youtube-stream.service
STREAM_SERVICE=adsb-streamnew-youtube-stream.service
DJ_SERVICE=adsb-streamnew-auto-dj.service
YTW_STREAM_SERVICE=adsb-streamnew-youtube-stream.service
STREAM_WATCHDOG_REMOTE_ONLY=1
YTW_INGEST_TCP_PORTS=443
YTW_STATE_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_watchdog_state.json
YTW_LOG_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/logs/youtube_watchdog.jsonl
YTW_STATS_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_watchdog_stats.json
YTW_API_CALL_LOG_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/logs/youtube_api_calls.jsonl
YTW_VIDEO_RESOLVER_STATE_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_video_id_resolver_state.json
YTW_VIDEO_RESOLVER_EVENT_LOG_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/logs/youtube_video_id_resolver_events.jsonl
YTW_OAUTH_TOKEN_STATE_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_oauth_token_state.json
YTW_QUOTA_STATE_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_quota_state.json
YTW_FORCE_LIVE_STATE_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/youtube_force_live_state.json
YTW_API_COST_REPORT_OUTPUT_DIR=/home/yuki/projects/stream_v3/.state/observability-monitor/reports/youtube_api_cost
YTW_API_COST_REPORT_LATEST_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/reports/youtube_api_cost/latest.json
YTW_API_COST_BURN_RATE_LATEST_FILE=/home/yuki/projects/stream_v3/.state/observability-monitor/reports/youtube_api_cost/open_day_latest.json
