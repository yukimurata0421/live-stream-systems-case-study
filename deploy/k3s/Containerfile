FROM debian:12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        chromium \
        curl \
        ffmpeg \
        fonts-dejavu-core \
        fonts-noto-cjk \
        iproute2 \
        iputils-ping \
        kubernetes-client \
        openssh-client \
        procps \
        pulseaudio \
        pulseaudio-utils \
        rsync \
        python3 \
        python3-venv \
        x11-utils \
        xvfb \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . /app

ENV BASE_DIR=/app \
    STREAM_BASE_DIR=/app \
    PYTHONPATH=/app/src \
    STREAM_RUNTIME_STATE_DIR=/state \
    STREAM_RUNTIME_LOG_DIR=/state/logs \
    STREAM_V2_STATE_ROOT=/state \
    TEST_MODE=1 \
    REQUIRE_SYSTEMD_LAUNCH=0 \
    ALLOW_DIRECT_STREAM_SH=1

RUN mkdir -p /state/logs /state/capture /state/locks

ENTRYPOINT ["/app/bin/stream-prod"]
CMD ["status"]
